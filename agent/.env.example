# Terminal 3 Travel Agent - Environment Configuration
# Copy to .env and fill in your keys

# Required: Get from https://www.terminal3.io/claim-page
T3N_API_KEY=""

# Agent configuration
AGENT_NAME="TravelBookingAgent"
AGENT_URI="http://localhost:3001"

# Travel API configuration
TRAVEL_API_BASE="https://api.terminal3.io"

# User DID (the data owner who delegates to this agent)
# Get this from the T3N dashboard after claiming tokens
USER_DID=""
